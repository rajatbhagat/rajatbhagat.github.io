---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 — Page not found">
  <section>
    <h1>404</h1>
    <p class="muted">That page doesn't exist (or moved).</p>
    <p><a href="/">← Back home</a></p>
  </section>
</BaseLayout>

<style>
  section {
    text-align: center;
    margin-top: 5rem;
  }

  h1 {
    font-size: 4rem;
    margin-bottom: 0;
  }
</style>
