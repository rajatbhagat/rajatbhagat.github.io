---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import site from '../data/site.json';

const projects = (await getCollection('projects')).sort(
  (a, b) => a.data.order - b.data.order
);
const rendered = await Promise.all(
  projects.map(async (project) => ({ project, Content: (await render(project)).Content }))
);
---

<BaseLayout
  title={`Projects — ${site.name}`}
  description={`Selected personal and learning projects by ${site.name}.`}
>
  <h1>Projects</h1>
  <p class="muted">
    A selection of personal projects. More on
    <a href={site.github} target="_blank" rel="noopener">GitHub</a>.
  </p>

  <div class="grid">
    {
      rendered.map(({ project, Content }) => (
        <article class="card">
          <h2>{project.data.name}</h2>
          <div class="desc muted">
            <Content />
          </div>
          <p class="tech">
            {project.data.tech.map((t) => (
              <span class="pill">{t}</span>
            ))}
          </p>
          <p class="links">
            {project.data.links.map((link) => (
              <a href={link.url} target="_blank" rel="noopener">
                {link.label} ↗
              </a>
            ))}
          </p>
        </article>
      ))
    }
  </div>
</BaseLayout>

<style>
  h1 {
    margin-top: 2.5rem;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1.25rem;
    margin-top: 1.5rem;
  }

  .card {
    display: flex;
    flex-direction: column;
  }

  h2 {
    margin: 0 0 0.5rem;
    font-size: 1.2rem;
  }

  .desc {
    flex: 1;
    margin: 0 0 0.75rem;
    font-size: 0.95rem;
  }

  .desc :global(p) {
    margin: 0 0 0.5rem;
  }

  .tech {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin: 0 0 0.75rem;
  }

  .links {
    margin: 0;
    display: flex;
    gap: 1rem;
  }
</style>
