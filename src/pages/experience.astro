---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import site from '../data/site.json';

const roles = (await getCollection('experience')).sort(
  (a, b) => a.data.order - b.data.order || a.id.localeCompare(b.id)
);
const rendered = await Promise.all(
  roles.map(async (role) => ({ role, Content: (await render(role)).Content }))
);
const { education, certifications } = site;
---

<BaseLayout
  title={`Experience — ${site.name}`}
  description={`Professional experience of ${site.name}.`}
>
  <h1>Experience</h1>

  <div class="timeline">
    {
      rendered.map(({ role, Content }) => (
        <section class="card role">
          <div class="role-header">
            <div>
              <h2>{role.data.company}</h2>
              <p class="title">{role.data.title}</p>
            </div>
            <div class="when muted">
              <p>{role.data.period}</p>
              <p>{role.data.location}</p>
            </div>
          </div>
          <div class="bullets">
            <Content />
          </div>
        </section>
      ))
    }
  </div>

  <h2 class="section-title">Education</h2>
  <section class="card">
    <div class="role-header">
      <div>
        <h2>{education.school}</h2>
        <p class="title">{education.degree} · {education.detail}</p>
      </div>
      <div class="when muted">
        <p>{education.period}</p>
      </div>
    </div>
  </section>

  <h2 class="section-title">Certifications & Achievements</h2>
  <ul class="certs">
    {certifications.map((c) => <li>{c}</li>)}
  </ul>
</BaseLayout>

<style>
  h1 {
    margin-top: 2.5rem;
  }

  .timeline {
    display: grid;
    gap: 1.25rem;
  }

  .role-header {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .role-header h2 {
    margin: 0;
    font-size: 1.25rem;
  }

  .title {
    margin: 0.2rem 0 0;
    font-weight: 600;
    color: var(--accent);
  }

  .when {
    text-align: right;
    font-size: 0.9rem;
  }

  .when p {
    margin: 0;
  }

  .bullets :global(ul) {
    margin: 1rem 0 0;
    padding-left: 1.25rem;
  }

  .bullets :global(li) {
    margin-bottom: 0.4rem;
    font-size: 0.95rem;
  }

  .certs {
    padding-left: 1.25rem;
  }

  .certs li {
    margin-bottom: 0.4rem;
  }
</style>
