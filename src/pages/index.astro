---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import site from '../data/site.json';
import profileImg from '../assets/profile.jpg';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<BaseLayout title={`${site.name} — Software Engineer`}>
  <section class="hero">
    <Image src={profileImg} alt={site.name} class="avatar" width={180} height={180} densities={[1, 2]} />
    <div>
      <h1>{site.heroGreeting}</h1>
      <p class="tagline">{site.tagline}</p>
      <p class="pill">{site.openToCallout}</p>
      <p class="links">
        <a href={`mailto:${site.email}`}>Email</a> ·
        <a href={site.linkedin} target="_blank" rel="noopener">LinkedIn</a> ·
        <a href={site.github} target="_blank" rel="noopener">GitHub</a> ·
        {site.location}
      </p>
    </div>
  </section>

  <h2 class="section-title">What I work with</h2>
  <div class="skills">
    {
      site.skills.map(({ group, items }) => (
        <div class="card">
          <h3>{group}</h3>
          <p class="muted">{items}</p>
        </div>
      ))
    }
  </div>

  <h2 class="section-title">Highlights</h2>
  <ul class="highlights">
    {site.highlights.map((h) => <li>{h}</li>)}
  </ul>

  {
    posts.length > 0 && (
      <>
        <h2 class="section-title">Latest from the blog</h2>
        <div class="post-list">
          {posts.map((post) => (
            <PostCard post={post} />
          ))}
        </div>
        <p>
          <a href="/blog/">All posts →</a>
        </p>
      </>
    )
  }
</BaseLayout>

<style>
  .hero {
    display: flex;
    align-items: center;
    gap: 2rem;
    margin-top: 3rem;
    flex-wrap: wrap;
  }

  .avatar {
    border-radius: 50%;
    object-fit: cover;
    border: 3px solid var(--border);
  }

  h1 {
    margin: 0 0 0.5rem;
    font-size: 2.2rem;
  }

  .tagline {
    max-width: 42rem;
    margin: 0 0 0.75rem;
    color: var(--text-muted);
  }

  .links {
    margin-top: 0.75rem;
    font-size: 0.95rem;
  }

  .skills {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1rem;
  }

  .skills h3 {
    margin: 0 0 0.35rem;
    font-size: 1rem;
  }

  .skills p {
    margin: 0;
    font-size: 0.92rem;
  }

  .highlights {
    padding-left: 1.25rem;
  }

  .highlights li {
    margin-bottom: 0.4rem;
  }

  .post-list {
    display: grid;
    gap: 1rem;
  }
</style>
