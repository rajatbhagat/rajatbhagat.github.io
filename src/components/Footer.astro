---
import site from '../data/site.json';

const year = new Date().getFullYear();
---

<footer>
  <div class="container">
    <p>
      © <span id="copyright-year">{year}</span> {site.name} ·
      <a href={`mailto:${site.email}`}>Email</a> ·
      <a href={site.linkedin} target="_blank" rel="noopener">LinkedIn</a> ·
      <a href={site.github} target="_blank" rel="noopener">GitHub</a>
    </p>
  </div>
</footer>

<script>
  // The build-time year goes stale on a static site; correct it client-side.
  // astro:page-load re-fires after each view-transition swap.
  function setYear() {
    const el = document.getElementById('copyright-year');
    if (el) el.textContent = String(new Date().getFullYear());
  }
  document.addEventListener('astro:page-load', setYear);
</script>

<style>
  footer {
    border-top: 1px solid var(--border);
    margin-top: 4rem;
    padding: 1.5rem 0 2rem;
    font-size: 0.9rem;
    color: var(--text-muted);
  }
</style>
