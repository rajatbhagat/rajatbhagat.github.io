---
import site from '../data/site.json';

const navItems = [
  { href: '/', label: 'Home' },
  { href: '/experience/', label: 'Experience' },
  { href: '/projects/', label: 'Projects' },
  { href: '/blog/', label: 'Blog' },
  { href: '/chat/', label: 'Ask My Resume' },
];

// Normalize the trailing slash so /experience and /experience/ both match.
const currentPath = Astro.url.pathname.endsWith('/')
  ? Astro.url.pathname
  : `${Astro.url.pathname}/`;
const isActive = (href: string) =>
  href === '/' ? currentPath === '/' : currentPath.startsWith(href);
---

<header>
  <nav class="container">
    <a href="/" class="brand">{site.brandName}</a>
    <div class="nav-right">
    <ul id="site-nav">
      {
        navItems.map((item) => (
          <li>
            <a
              href={item.href}
              class:list={[{ active: isActive(item.href) }]}
              aria-current={isActive(item.href) ? 'page' : undefined}
            >
              {item.label}
            </a>
          </li>
        ))
      }
    </ul>
    <button id="theme-toggle" aria-label="Toggle light/dark theme" title="Toggle theme">
      <svg class="icon-sun" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <circle cx="12" cy="12" r="4" />
        <path d="M12 2v2m0 16v2M4.9 4.9l1.4 1.4m11.4 11.4 1.4 1.4M2 12h2m16 0h2M4.9 19.1l1.4-1.4m11.4-11.4 1.4-1.4" />
      </svg>
      <svg class="icon-moon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8Z" />
      </svg>
    </button>
    <button id="nav-toggle" aria-label="Open menu" aria-expanded="false" aria-controls="site-nav">
      <svg class="icon-menu" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <line x1="3" y1="6" x2="21" y2="6" />
        <line x1="3" y1="12" x2="21" y2="12" />
        <line x1="3" y1="18" x2="21" y2="18" />
      </svg>
      <svg class="icon-x" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <line x1="18" y1="6" x2="6" y2="18" />
        <line x1="6" y1="6" x2="18" y2="18" />
      </svg>
    </button>
    </div>
  </nav>
  <div class="nav-backdrop"></div>
</header>

<script>
  // Re-attach on every navigation: view transitions replace the button element.
  function initThemeToggle() {
    document.getElementById('theme-toggle')?.addEventListener('click', () => {
      const next = document.documentElement.dataset.theme === 'dark' ? 'light' : 'dark';
      document.documentElement.dataset.theme = next;
      localStorage.setItem('theme', next);
    });
  }
  document.addEventListener('astro:page-load', initThemeToggle);

  // Mobile nav drawer. The header is re-rendered on every navigation, so the
  // drawer always starts closed; the body scroll-lock class is cleared here
  // for the same reason.
  function initNavDrawer() {
    document.body.classList.remove('nav-drawer-open');
    const header = document.querySelector('header');
    const toggle = document.getElementById('nav-toggle');
    if (!header || !toggle) return;
    const setOpen = (open: boolean) => {
      header.classList.toggle('nav-open', open);
      toggle.setAttribute('aria-expanded', String(open));
      toggle.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
      document.body.classList.toggle('nav-drawer-open', open);
    };
    toggle.addEventListener('click', () => setOpen(!header.classList.contains('nav-open')));
    header.querySelector('.nav-backdrop')?.addEventListener('click', () => setOpen(false));
  }
  document.addEventListener('astro:page-load', initNavDrawer);

  // Registered once (module scope) so navigations don't stack handlers.
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      document.querySelector<HTMLButtonElement>('header.nav-open #nav-toggle')?.click();
    }
  });
</script>

<style>
  header {
    border-bottom: 1px solid var(--border);
    position: sticky;
    top: 0;
    background: var(--bg);
    z-index: 10;
  }

  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 0.85rem;
    padding-bottom: 0.85rem;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .brand {
    font-weight: 700;
    font-size: 1.1rem;
    color: var(--text);
  }

  .brand:hover {
    text-decoration: none;
    color: var(--accent);
  }

  ul {
    display: flex;
    gap: 1.25rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  ul a {
    color: var(--text-muted);
    font-weight: 500;
    font-size: 0.95rem;
  }

  ul a:hover {
    color: var(--accent);
    text-decoration: none;
  }

  ul a.active {
    color: var(--accent);
  }

  .nav-right {
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }

  #theme-toggle {
    display: flex;
    align-items: center;
    background: none;
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 0.35rem;
    cursor: pointer;
    color: var(--text-muted);
  }

  #theme-toggle:hover {
    color: var(--accent);
    border-color: var(--accent);
  }

  #nav-toggle {
    display: none;
    align-items: center;
    background: none;
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 0.35rem;
    cursor: pointer;
    color: var(--text-muted);
    position: relative;
    z-index: 40;
  }

  #nav-toggle:hover {
    color: var(--accent);
    border-color: var(--accent);
  }

  #nav-toggle .icon-x,
  header.nav-open #nav-toggle .icon-menu {
    display: none;
  }

  header.nav-open #nav-toggle .icon-x {
    display: block;
  }

  .nav-backdrop {
    display: none;
  }

  @media (max-width: 720px) {
    #nav-toggle {
      display: flex;
    }

    ul {
      position: fixed;
      top: 0;
      right: 0;
      height: 100vh;
      height: 100dvh;
      width: min(75vw, 300px);
      flex-direction: column;
      gap: 0.25rem;
      margin: 0;
      padding: 4.5rem 1rem 1.5rem;
      background: var(--bg);
      border-left: 1px solid var(--border);
      box-shadow: -8px 0 30px rgba(0, 0, 0, 0.15);
      transform: translateX(100%);
      transition: transform 0.25s ease;
      z-index: 30;
    }

    header.nav-open ul {
      transform: none;
    }

    ul a {
      display: block;
      padding: 0.6rem 0.75rem;
      border-radius: 8px;
      font-size: 1.05rem;
    }

    ul a:hover {
      background: var(--bg-soft);
      text-decoration: none;
    }

    .nav-backdrop {
      display: block;
      position: fixed;
      inset: 0;
      background: rgba(0, 0, 0, 0.45);
      opacity: 0;
      visibility: hidden;
      transition: opacity 0.25s ease, visibility 0.25s ease;
      z-index: 20;
    }

    header.nav-open .nav-backdrop {
      opacity: 1;
      visibility: visible;
    }

    :global(body.nav-drawer-open) {
      overflow: hidden;
    }
  }

  /* Show the icon for the theme you'd switch TO: moon in light mode, sun in dark */
  .icon-sun {
    display: none;
  }

  :global(html[data-theme='dark']) #theme-toggle .icon-sun {
    display: block;
  }

  :global(html[data-theme='dark']) #theme-toggle .icon-moon {
    display: none;
  }
</style>
