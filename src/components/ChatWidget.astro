---
import site from '../data/site.json';
import { MODELS, DEFAULT_MODEL } from '../../chatbot/src/models';

interface Props {
  /** 'floating' = bubble + popup panel (default); 'page' = inline, always-open panel */
  variant?: 'floating' | 'page';
}

const { variant = 'floating' } = Astro.props;
const isPage = variant === 'page';

// Dormant-by-default: the widget only renders when an endpoint is configured
// in site.json. In dev it falls back to the local worker (`npm run dev` in
// chatbot/) so it can be tested without touching config.
const endpoint =
  site.chatEndpoint || (import.meta.env.DEV ? 'http://localhost:8787/chat' : '');
---

{
  endpoint ? (
    <div
      class:list={['chat-widget', isPage ? 'chat-page' : 'chat-floating']}
      data-endpoint={endpoint}
      transition:persist={isPage ? 'chat-page' : 'chat-widget'}
    >
      <section class="chat-panel" hidden={!isPage} aria-label="Resume chat">
        <header class="chat-head">
          <div class="chat-head-text">
            <strong>Ask My Resume</strong>
            <span class="chat-sub muted">
            AI answers based on this site's content — please don't share personal info
          </span>
          </div>
          {!isPage && (
            <button class="chat-close" type="button" aria-label="Close chat">
              <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <line x1="18" y1="6" x2="6" y2="18" />
                <line x1="6" y1="6" x2="18" y2="18" />
              </svg>
            </button>
          )}
        </header>
        <div class="chat-log" aria-live="polite" />
        <form class="chat-form">
          {isPage && (
            <div class="chat-model">
              <button
                type="button"
                class="chat-model-btn"
                aria-haspopup="listbox"
                aria-expanded="false"
                aria-label="Choose the AI model"
                title={`Switch model (current: ${MODELS[DEFAULT_MODEL].label})`}
              >
                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <rect x="4" y="4" width="16" height="16" rx="2" />
                  <rect x="9.5" y="9.5" width="5" height="5" fill="currentColor" stroke="none" />
                  <line x1="9" y1="1.5" x2="9" y2="4" />
                  <line x1="15" y1="1.5" x2="15" y2="4" />
                  <line x1="9" y1="20" x2="9" y2="22.5" />
                  <line x1="15" y1="20" x2="15" y2="22.5" />
                  <line x1="20" y1="9" x2="22.5" y2="9" />
                  <line x1="20" y1="15" x2="22.5" y2="15" />
                  <line x1="1.5" y1="9" x2="4" y2="9" />
                  <line x1="1.5" y1="15" x2="4" y2="15" />
                </svg>
              </button>
              <ul class="chat-model-menu" role="listbox" aria-label="AI model" hidden>
                {Object.entries(MODELS).map(([key, m]) => (
                  <li>
                    <button
                      type="button"
                      role="option"
                      data-model={key}
                      aria-selected={key === DEFAULT_MODEL ? 'true' : 'false'}
                    >
                      <span>{m.label}</span>
                      <svg class="chat-model-check" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <polyline points="20 6 9 17 4 12" />
                      </svg>
                    </button>
                  </li>
                ))}
              </ul>
            </div>
          )}
          <input
            class="chat-input"
            type="text"
            maxlength="500"
            placeholder="e.g. Does Rajat know Kafka?"
            aria-label="Your question"
            autocomplete="off"
            required
          />
          <button class="chat-send" type="submit" aria-label="Send question">
            <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <line x1="22" y1="2" x2="11" y2="13" />
              <polygon points="22 2 15 22 11 13 2 9 22 2" />
            </svg>
          </button>
        </form>
      </section>
      {!isPage && (
        <div class="chat-teaser" hidden>
          <span>&#128075; Have questions about Rajat? Ask my AI assistant.</span>
          <button class="chat-teaser-close" type="button" aria-label="Dismiss">
            <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
              <line x1="18" y1="6" x2="6" y2="18" />
              <line x1="6" y1="6" x2="18" y2="18" />
            </svg>
          </button>
        </div>
      )}
      {!isPage && (
        <button class="chat-toggle" aria-label="Chat about my experience" aria-expanded="false">
          <svg class="icon-open" viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z" />
          </svg>
          <svg class="icon-close" viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="18" y1="6" x2="6" y2="18" />
            <line x1="6" y1="6" x2="18" y2="18" />
          </svg>
        </button>
      )}
    </div>
  ) : (
    isPage && <p class="muted">The chat assistant is offline right now — please check back later.</p>
  )
}

<script>
  // View transitions swap in fresh DOM without re-running this module, so
  // init must re-run on every navigation (same pattern as the Header theme
  // toggle). Nodes that survived a swap via transition:persist keep their
  // listeners and are skipped via the data-chat-init marker.
  function initAll() {
    document
      .querySelectorAll<HTMLElement>('.chat-widget:not([data-chat-init])')
      .forEach((el) => {
        el.dataset.chatInit = '';
        initChat(el);
      });
  }
  document.addEventListener('astro:page-load', initAll);

  // The teaser greets every arrival on the home page (dismissal only lasts
  // until the next home visit). Runs after initAll on each navigation;
  // registered second, so the widget node already exists.
  let teaserTimer: number | undefined;
  function updateTeaser() {
    clearTimeout(teaserTimer);
    const widget = document.querySelector<HTMLElement>('.chat-widget.chat-floating');
    const teaser = widget?.querySelector<HTMLElement>('.chat-teaser');
    if (!teaser) return;
    teaser.hidden = true;
    const panel = widget!.querySelector<HTMLElement>('.chat-panel')!;
    if (location.pathname === '/' && panel.hidden) {
      teaserTimer = window.setTimeout(() => {
        if (panel.hidden) teaser.hidden = false;
      }, 1500);
    }
  }
  document.addEventListener('astro:page-load', updateTeaser);

  // Close the model menu when clicking anywhere outside it (delegated once
  // at module level so /chat revisits don't stack document listeners).
  document.addEventListener('click', (e) => {
    const wrap = document.querySelector<HTMLElement>('.chat-model');
    if (wrap && !wrap.contains(e.target as Node)) {
      wrap.querySelector('.chat-model-menu')?.setAttribute('hidden', '');
      wrap.querySelector('.chat-model-btn')?.setAttribute('aria-expanded', 'false');
    }
  });

  // One document-level listener (instead of one per init) so repeated
  // navigations don't stack handlers; it closes whichever floating panel
  // is currently in the DOM.
  document.addEventListener('keydown', (e) => {
    if (e.key !== 'Escape') return;
    const panel = document.querySelector<HTMLElement>('.chat-floating .chat-panel');
    if (panel && !panel.hidden) {
      panel.querySelector<HTMLButtonElement>('.chat-close')?.click();
    }
  });

  // --- Minimal markdown renderer for model answers ---------------------
  // Escape-first, then apply a whitelisted subset (bold, italics, inline
  // code, fenced code, http(s) links, lists, headings-as-bold). Everything
  // the model emits is HTML-escaped before any tags are introduced, so the
  // only HTML in the output is ours.

  function escapeHtml(s: string): string {
    return s
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;');
  }

  function inlineMd(s: string): string {
    return s
      .replace(/`([^`]+)`/g, '<code>$1</code>')
      .replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>')
      .replace(/\*([^*]+)\*/g, '<em>$1</em>')
      .replace(
        /\[([^\]]+)\]\((https?:\/\/[^)\s]+)\)/g,
        '<a href="$2" target="_blank" rel="noopener noreferrer">$1</a>',
      )
      // Auto-link bare URLs the model didn't wrap in markdown. The prefix
      // guard (start/whitespace/paren) skips URLs already inside the href="
      // or >text</a> produced by the rule above; trailing punctuation stays
      // outside the link.
      .replace(/(^|[\s(])(https?:\/\/[^\s<)]+)/g, (_m, pre: string, url: string) => {
        const clean = url.replace(/[.,;:!?]+$/, '');
        const rest = url.slice(clean.length);
        return `${pre}<a href="${clean}" target="_blank" rel="noopener noreferrer">${clean}</a>${rest}`;
      });
  }

  function renderMarkdown(md: string): string {
    const lines = escapeHtml(md).split('\n');
    const out: string[] = [];
    let para: string[] = [];
    let list: { tag: 'ul' | 'ol'; items: string[] } | null = null;
    let code: string[] | null = null;
    let table: string[] | null = null;

    const flushPara = () => {
      if (para.length) out.push(`<p>${para.join('<br>')}</p>`);
      para = [];
    };
    const flushList = () => {
      if (list) out.push(`<${list.tag}>${list.items.map((i) => `<li>${i}</li>`).join('')}</${list.tag}>`);
      list = null;
    };
    // GitHub-flavored pipe tables. Cells were HTML-escaped up front, so this
    // only introduces our own <table>/<th>/<td> tags around escaped content.
    const cells = (row: string): string[] => {
      let s = row.trim();
      if (s.startsWith('|')) s = s.slice(1);
      if (s.endsWith('|')) s = s.slice(0, -1);
      return s.split('|').map((c) => c.trim());
    };
    const isSeparator = (row: string): boolean => {
      const cs = cells(row);
      return cs.length > 0 && cs.every((c) => /^:?-+:?$/.test(c));
    };
    const flushTable = () => {
      if (!table) return;
      const rows = table;
      table = null;
      // A real table needs a header row + a `|---|` separator; otherwise the
      // buffered pipe lines fall back to plain paragraphs (nothing lost, and
      // it avoids mangling half-streamed tables).
      if (rows.length >= 2 && isSeparator(rows[1]!)) {
        const head = cells(rows[0]!).map((c) => `<th>${inlineMd(c)}</th>`).join('');
        const body = rows
          .slice(2)
          .map((r) => `<tr>${cells(r).map((c) => `<td>${inlineMd(c)}</td>`).join('')}</tr>`)
          .join('');
        out.push(
          `<div class="chat-table-wrap"><table><thead><tr>${head}</tr></thead><tbody>${body}</tbody></table></div>`,
        );
      } else {
        for (const r of rows) out.push(`<p>${inlineMd(r)}</p>`);
      }
    };

    for (const line of lines) {
      if (code) {
        if (/^```/.test(line)) {
          out.push(`<pre><code>${code.join('\n')}</code></pre>`);
          code = null;
        } else {
          code.push(line);
        }
        continue;
      }
      if (/^```/.test(line)) {
        flushPara();
        flushList();
        flushTable();
        code = [];
        continue;
      }
      // A line starting with `|` is a table row; buffer consecutive ones.
      if (/^\s*\|/.test(line)) {
        flushPara();
        flushList();
        (table ??= []).push(line);
        continue;
      }
      flushTable();
      const ul = line.match(/^\s*[-*]\s+(.*)/);
      const ol = line.match(/^\s*\d+[.)]\s+(.*)/);
      if (ul || ol) {
        flushPara();
        const tag = ul ? 'ul' : 'ol';
        if (!list || list.tag !== tag) {
          flushList();
          list = { tag, items: [] };
        }
        list.items.push(inlineMd((ul ?? ol)![1]!));
        continue;
      }
      flushList();
      const heading = line.match(/^#{1,6}\s+(.*)/);
      if (heading) {
        flushPara();
        out.push(`<p><strong>${inlineMd(heading[1]!)}</strong></p>`);
        continue;
      }
      if (!line.trim()) {
        flushPara();
        continue;
      }
      para.push(inlineMd(line));
    }
    if (code) out.push(`<pre><code>${code.join('\n')}</code></pre>`);
    flushTable();
    flushPara();
    flushList();
    return out.join('');
  }

  function initChat(root: HTMLElement) {
    const isPage = root.classList.contains('chat-page');
    const endpoint = root.dataset.endpoint!;
    const toggle = root.querySelector<HTMLButtonElement>('.chat-toggle');
    const panel = root.querySelector<HTMLElement>('.chat-panel')!;
    const log = root.querySelector<HTMLElement>('.chat-log')!;
    const form = root.querySelector<HTMLFormElement>('.chat-form')!;
    const input = root.querySelector<HTMLInputElement>('.chat-input')!;
    const send = root.querySelector<HTMLButtonElement>('.chat-send')!;

    // Model popover (page variant only): tracks the chosen key; the floating
    // widget sends none and gets the server default.
    let modelKey: string | undefined;
    const modelWrap = root.querySelector<HTMLElement>('.chat-model');
    if (modelWrap) {
      const modelBtn = modelWrap.querySelector<HTMLButtonElement>('.chat-model-btn')!;
      const menu = modelWrap.querySelector<HTMLElement>('.chat-model-menu')!;
      const options = [...menu.querySelectorAll<HTMLButtonElement>('[data-model]')];
      modelKey = options.find((o) => o.getAttribute('aria-selected') === 'true')?.dataset.model;

      const setMenu = (open: boolean) => {
        menu.hidden = !open;
        modelBtn.setAttribute('aria-expanded', String(open));
      };
      modelBtn.addEventListener('click', () => setMenu(menu.hidden));
      for (const option of options) {
        option.addEventListener('click', () => {
          modelKey = option.dataset.model;
          modelBtn.title = `Switch model (current: ${option.textContent!.trim()})`;
          for (const o of options) o.setAttribute('aria-selected', String(o === option));
          setMenu(false);
        });
      }
      root.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && !menu.hidden) setMenu(false);
      });
    }
    let busy = false;
    let greeted = false;

    // Conversation memory: completed exchanges, replayed with each request.
    // Lives in this closure — the floating widget's node (listeners, closure
    // and all) persists across view transitions, so "session" = the tab.
    // The worker re-validates and re-caps whatever arrives; this cap just
    // keeps requests small.
    const MAX_HISTORY_PAIRS = 4;
    const history: { role: 'user' | 'assistant'; content: string }[] = [];

    function addMsg(cls: string, text: string): HTMLElement {
      const div = document.createElement('div');
      div.className = `msg ${cls}`;
      div.textContent = text;
      log.appendChild(div);
      log.scrollTop = log.scrollHeight;
      return div;
    }

    function greet() {
      if (greeted) return;
      greeted = true;
      addMsg('bot', "Hi! Ask me anything about Rajat's experience, skills, or projects.");
    }

    function setOpen(open: boolean) {
      panel.hidden = !open;
      toggle?.setAttribute('aria-expanded', String(open));
      // Lets CSS lock background scroll while the mobile full-screen
      // panel is open (floating variant only).
      document.body.classList.toggle('chat-widget-open', open && !isPage);
      if (open) {
        dismissTeaser();
        greet();
        input.focus();
      }
    }

    // The teaser greets visitors on the home page (visibility is driven per
    // navigation by updateTeaser below); dismissing hides it until the next
    // home-page visit.
    const teaser = root.querySelector<HTMLElement>('.chat-teaser');
    function dismissTeaser() {
      teaser?.setAttribute('hidden', '');
    }

    if (isPage) {
      // Always open; no keyboard-popping autofocus on page load.
      greet();
    } else {
      toggle!.addEventListener('click', () => setOpen(panel.hidden));
      root.querySelector('.chat-close')!.addEventListener('click', () => setOpen(false));
      teaser?.querySelector('.chat-teaser-close')!.addEventListener('click', dismissTeaser);
    }

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const question = input.value.trim();
      if (!question || busy) return;
      busy = true;
      send.disabled = true;
      input.value = '';
      addMsg('user', question);
      // The model reasons before it answers — first token can take ~10s.
      const bot = addMsg('bot thinking', 'Thinking…');
      const fail = (text: string) => {
        bot.classList.remove('thinking');
        bot.classList.add('error');
        bot.textContent = text;
      };

      try {
        // `messages` is the recent conversation ending with the new question;
        // `question` stays so a worker that predates multi-turn still works.
        const messages = [
          ...history.slice(-2 * (MAX_HISTORY_PAIRS - 1)),
          { role: 'user', content: question },
        ];
        const res = await fetch(endpoint, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ question, model: modelKey, messages }),
        });
        if (!res.ok || !res.body) {
          fail(
            res.status === 429
              ? "I've hit my free usage limit right now — try again in a few minutes (on the chat page you can also switch models), or reach Rajat by email at rajat.bhagat@gmail.com"
              : 'Something went wrong — please try again in a moment.',
          );
          return;
        }
        const reader = res.body.pipeThrough(new TextDecoderStream()).getReader();
        let answer = '';
        for (;;) {
          const { done, value } = await reader.read();
          if (done) break;
          if (!answer) bot.classList.remove('thinking');
          answer += value;
          // Re-render the accumulated markdown on each chunk; answers are
          // short, so this stays cheap.
          bot.innerHTML = renderMarkdown(answer);
          log.scrollTop = log.scrollHeight;
        }
        if (!answer) {
          fail('No answer came back — please try again.');
        } else {
          // Only completed exchanges enter the history — a failed or partial
          // answer would pollute every later request's context.
          history.push({ role: 'user', content: question }, { role: 'assistant', content: answer });
          if (history.length > 2 * MAX_HISTORY_PAIRS) {
            history.splice(0, history.length - 2 * MAX_HISTORY_PAIRS);
          }
        }
      } catch {
        fail("Couldn't reach the chat service — please try again later.");
      } finally {
        busy = false;
        send.disabled = false;
        input.focus();
      }
    });
  }
</script>

{/* Global (namespaced) rather than scoped: message bubbles are created by JS
    at runtime, and Astro's scoped styles only match elements rendered from
    this template — dynamically created nodes would be unstyled. */}
<style is:global>
  .chat-widget.chat-floating {
    position: fixed;
    right: 1.25rem;
    bottom: 1.25rem;
    z-index: 50;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.75rem;
  }

  .chat-widget.chat-page {
    display: block;
    margin: 1.5rem 0 2.5rem;
  }

  .chat-widget .chat-teaser {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    max-width: 240px;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 0.6rem 0.75rem;
    font-size: 0.85rem;
    line-height: 1.4;
    box-shadow: 0 6px 24px rgba(0, 0, 0, 0.18);
    animation: chat-teaser-in 0.3s ease-out;
  }

  .chat-widget .chat-teaser[hidden] {
    display: none;
  }

  @keyframes chat-teaser-in {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
  }

  .chat-widget .chat-teaser-close {
    flex-shrink: 0;
    background: none;
    border: none;
    color: var(--text-muted);
    cursor: pointer;
    padding: 0.2rem;
    display: grid;
    place-items: center;
  }

  .chat-widget .chat-teaser-close:hover {
    color: var(--text);
  }

  .chat-widget .chat-toggle {
    width: 3.25rem;
    height: 3.25rem;
    border: none;
    border-radius: 999px;
    background: var(--accent);
    color: #fff;
    cursor: pointer;
    display: grid;
    place-items: center;
    box-shadow: 0 4px 14px rgba(0, 0, 0, 0.25);
  }

  .chat-widget .chat-toggle:hover {
    filter: brightness(1.1);
  }

  .chat-widget .chat-toggle .icon-close,
  .chat-widget .chat-toggle[aria-expanded='true'] .icon-open {
    display: none;
  }

  .chat-widget .chat-toggle[aria-expanded='true'] .icon-close {
    display: block;
  }

  .chat-widget .chat-panel {
    display: flex;
    flex-direction: column;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 12px;
    overflow: hidden;
  }

  .chat-floating .chat-panel {
    width: min(420px, calc(100vw - 2.5rem));
    height: min(600px, 75vh);
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.25);
  }

  .chat-page .chat-panel {
    width: 100%;
    height: min(72dvh, 720px);
    min-height: 420px;
  }

  .chat-widget .chat-panel[hidden] {
    display: none;
  }

  .chat-widget .chat-head {
    padding: 0.75rem 1rem;
    border-bottom: 1px solid var(--border);
    background: var(--bg-soft);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .chat-widget .chat-head-text {
    display: flex;
    flex-direction: column;
  }

  .chat-widget .chat-model {
    position: relative;
    flex-shrink: 0;
    display: grid;
  }

  .chat-widget .chat-model-btn {
    border: 1px solid var(--border);
    border-radius: 8px;
    background: var(--bg);
    color: var(--text-muted);
    padding: 0 0.6rem;
    height: 100%;
    cursor: pointer;
    display: grid;
    place-items: center;
  }

  .chat-widget .chat-model-btn:hover,
  .chat-widget .chat-model-btn[aria-expanded='true'] {
    color: var(--accent);
    border-color: var(--accent);
  }

  .chat-widget .chat-model-menu {
    position: absolute;
    bottom: calc(100% + 0.5rem);
    left: 0;
    min-width: 230px;
    margin: 0;
    padding: 0.3rem;
    list-style: none;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 12px;
    box-shadow: 0 10px 32px rgba(0, 0, 0, 0.22);
    z-index: 10;
  }

  .chat-widget .chat-model-menu[hidden] {
    display: none;
  }

  .chat-widget .chat-model-menu [role='option'] {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    padding: 0.5rem 0.75rem;
