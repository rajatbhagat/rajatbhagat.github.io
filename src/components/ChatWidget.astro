---
import site from '../data/site.json';

// Dormant-by-default: the widget only renders when an endpoint is configured
// in site.json. In dev it falls back to the local worker (`npm run dev` in
// chatbot/) so it can be tested without touching config.
const endpoint =
  site.chatEndpoint || (import.meta.env.DEV ? 'http://localhost:8787/chat' : '');
---

{
  endpoint && (
    <div class="chat-widget" data-endpoint={endpoint} transition:persist="chat-widget">
      <section class="chat-panel" hidden aria-label="Resume chat">
        <header class="chat-head">
          <strong>Ask my resume</strong>
          <span class="chat-sub muted">AI answers based on this site's content</span>
        </header>
        <div class="chat-log" aria-live="polite" />
        <form class="chat-form">
          <input
            class="chat-input"
            type="text"
            maxlength="500"
            placeholder="e.g. Does Rajat know Kafka?"
            aria-label="Your question"
            autocomplete="off"
            required
          />
          <button class="chat-send" type="submit" aria-label="Send question">
            <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <line x1="22" y1="2" x2="11" y2="13" />
              <polygon points="22 2 15 22 11 13 2 9 22 2" />
            </svg>
          </button>
        </form>
      </section>
      <button class="chat-toggle" aria-label="Chat about my experience" aria-expanded="false">
        <svg class="icon-open" viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z" />
        </svg>
        <svg class="icon-close" viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="18" y1="6" x2="6" y2="18" />
          <line x1="6" y1="6" x2="18" y2="18" />
        </svg>
      </button>
    </div>
  )
}

<script>
  // The wrapper carries transition:persist, so this node (listeners, chat
  // history and all) survives view-transition navigations — the module runs
  // once per full page load, which is exactly what we want.
  const root = document.querySelector<HTMLElement>('.chat-widget');
  if (root) initChat(root);

  // --- Minimal markdown renderer for model answers ---------------------
  // Escape-first, then apply a whitelisted subset (bold, italics, inline
  // code, fenced code, http(s) links, lists, headings-as-bold). Everything
  // the model emits is HTML-escaped before any tags are introduced, so the
  // only HTML in the output is ours.

  function escapeHtml(s: string): string {
    return s
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;');
  }

  function inlineMd(s: string): string {
    return s
      .replace(/`([^`]+)`/g, '<code>$1</code>')
      .replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>')
      .replace(/\*([^*]+)\*/g, '<em>$1</em>')
      .replace(
        /\[([^\]]+)\]\((https?:\/\/[^)\s]+)\)/g,
        '<a href="$2" target="_blank" rel="noopener noreferrer">$1</a>',
      );
  }

  function renderMarkdown(md: string): string {
    const lines = escapeHtml(md).split('\n');
    const out: string[] = [];
    let para: string[] = [];
    let list: { tag: 'ul' | 'ol'; items: string[] } | null = null;
    let code: string[] | null = null;

    const flushPara = () => {
      if (para.length) out.push(`<p>${para.join('<br>')}</p>`);
      para = [];
    };
    const flushList = () => {
      if (list) out.push(`<${list.tag}>${list.items.map((i) => `<li>${i}</li>`).join('')}</${list.tag}>`);
      list = null;
    };

    for (const line of lines) {
      if (code) {
        if (/^```/.test(line)) {
          out.push(`<pre><code>${code.join('\n')}</code></pre>`);
          code = null;
        } else {
          code.push(line);
        }
        continue;
      }
      if (/^```/.test(line)) {
        flushPara();
        flushList();
        code = [];
        continue;
      }
      const ul = line.match(/^\s*[-*]\s+(.*)/);
      const ol = line.match(/^\s*\d+[.)]\s+(.*)/);
      if (ul || ol) {
        flushPara();
        const tag = ul ? 'ul' : 'ol';
        if (!list || list.tag !== tag) {
          flushList();
          list = { tag, items: [] };
        }
        list.items.push(inlineMd((ul ?? ol)![1]!));
        continue;
      }
      flushList();
      const heading = line.match(/^#{1,6}\s+(.*)/);
      if (heading) {
        flushPara();
        out.push(`<p><strong>${inlineMd(heading[1]!)}</strong></p>`);
        continue;
      }
      if (!line.trim()) {
        flushPara();
        continue;
      }
      para.push(inlineMd(line));
    }
    if (code) out.push(`<pre><code>${code.join('\n')}</code></pre>`);
    flushPara();
    flushList();
    return out.join('');
  }

  function initChat(root: HTMLElement) {
    const endpoint = root.dataset.endpoint!;
    const toggle = root.querySelector<HTMLButtonElement>('.chat-toggle')!;
    const panel = root.querySelector<HTMLElement>('.chat-panel')!;
    const log = root.querySelector<HTMLElement>('.chat-log')!;
    const form = root.querySelector<HTMLFormElement>('.chat-form')!;
    const input = root.querySelector<HTMLInputElement>('.chat-input')!;
    const send = root.querySelector<HTMLButtonElement>('.chat-send')!;
    let busy = false;
    let greeted = false;

    function addMsg(cls: string, text: string): HTMLElement {
      const div = document.createElement('div');
      div.className = `msg ${cls}`;
      div.textContent = text;
      log.appendChild(div);
      log.scrollTop = log.scrollHeight;
      return div;
    }

    function setOpen(open: boolean) {
      panel.hidden = !open;
      toggle.setAttribute('aria-expanded', String(open));
      if (open) {
        if (!greeted) {
          greeted = true;
          addMsg('bot', "Hi! Ask me anything about Rajat's experience, skills, or projects.");
        }
        input.focus();
      }
    }

    toggle.addEventListener('click', () => setOpen(panel.hidden));
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !panel.hidden) setOpen(false);
    });

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const question = input.value.trim();
      if (!question || busy) return;
      busy = true;
      send.disabled = true;
      input.value = '';
      addMsg('user', question);
      // The model reasons before it answers — first token can take ~10s.
      const bot = addMsg('bot thinking', 'Thinking…');
      const fail = (text: string) => {
        bot.classList.remove('thinking');
        bot.classList.add('error');
        bot.textContent = text;
      };

      try {
        const res = await fetch(endpoint, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ question }),
        });
        if (!res.ok || !res.body) {
          fail(
            res.status === 429
              ? "I've hit my answer limit for today — please try again tomorrow, or reach Rajat by email."
              : 'Something went wrong — please try again in a moment.',
          );
          return;
        }
        const reader = res.body.pipeThrough(new TextDecoderStream()).getReader();
        let answer = '';
        for (;;) {
          const { done, value } = await reader.read();
          if (done) break;
          if (!answer) bot.classList.remove('thinking');
          answer += value;
          // Re-render the accumulated markdown on each chunk; answers are
          // short, so this stays cheap.
          bot.innerHTML = renderMarkdown(answer);
          log.scrollTop = log.scrollHeight;
        }
        if (!answer) fail('No answer came back — please try again.');
      } catch {
        fail("Couldn't reach the chat service — please try again later.");
      } finally {
        busy = false;
        send.disabled = false;
        input.focus();
      }
    });
  }
</script>

{/* Global (namespaced) rather than scoped: message bubbles are created by JS
    at runtime, and Astro's scoped styles only match elements rendered from
    this template — dynamically created nodes would be unstyled. */}
<style is:global>
  .chat-widget {
    position: fixed;
    right: 1.25rem;
    bottom: 1.25rem;
    z-index: 50;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.75rem;
  }

  .chat-widget .chat-toggle {
    width: 3.25rem;
    height: 3.25rem;
    border: none;
    border-radius: 999px;
    background: var(--accent);
    color: #fff;
    cursor: pointer;
    display: grid;
    place-items: center;
    box-shadow: 0 4px 14px rgba(0, 0, 0, 0.25);
  }

  .chat-widget .chat-toggle:hover {
    filter: brightness(1.1);
  }

  .chat-widget .chat-toggle .icon-close,
  .chat-widget .chat-toggle[aria-expanded='true'] .icon-open {
    display: none;
  }

  .chat-widget .chat-toggle[aria-expanded='true'] .icon-close {
    display: block;
  }

  .chat-widget .chat-panel {
    width: min(420px, calc(100vw - 2.5rem));
    height: min(600px, 75vh);
    display: flex;
    flex-direction: column;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 12px;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.25);
    overflow: hidden;
  }

  .chat-widget .chat-panel[hidden] {
    display: none;
  }

  .chat-widget .chat-head {
    padding: 0.75rem 1rem;
    border-bottom: 1px solid var(--border);
    background: var(--bg-soft);
    display: flex;
    flex-direction: column;
  }

  .chat-widget .chat-sub {
    font-size: 0.75rem;
  }

  .chat-widget .chat-log {
    flex: 1;
    overflow-y: auto;
    padding: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .chat-widget .msg {
    max-width: 88%;
    padding: 0.55rem 0.8rem;
    border-radius: 12px;
    font-size: 0.92rem;
    line-height: 1.55;
    overflow-wrap: anywhere;
  }

  .chat-widget .msg.user {
    align-self: flex-end;
    background: var(--accent);
    color: #fff;
    border-bottom-right-radius: 4px;
    white-space: pre-wrap;
  }

  .chat-widget .msg.bot {
    align-self: flex-start;
    background: var(--bg-soft);
    border: 1px solid var(--border);
    border-bottom-left-radius: 4px;
  }

  .chat-widget .msg.error {
    color: #e5484d;
  }

  .chat-widget .msg.thinking {
    color: var(--text-muted);
    animation: chat-pulse 1.4s ease-in-out infinite;
  }

  @keyframes chat-pulse {
    50% {
      opacity: 0.45;
    }
  }

  /* Rendered-markdown elements inside bot bubbles */
  .chat-widget .msg p {
    margin: 0 0 0.5em;
  }

  .chat-widget .msg p:last-child {
    margin-bottom: 0;
  }

  .chat-widget .msg ul,
  .chat-widget .msg ol {
    margin: 0.25em 0 0.5em;
    padding-left: 1.3em;
  }

  .chat-widget .msg li {
    margin: 0.15em 0;
  }

  .chat-widget .msg pre {
    margin: 0.5em 0;
    padding: 0.5em 0.75em;
    font-size: 0.85em;
  }

  .chat-widget .chat-form {
    display: flex;
    gap: 0.5rem;
    padding: 0.75rem;
    border-top: 1px solid var(--border);
  }

  .chat-widget .chat-input {
    flex: 1;
    padding: 0.5rem 0.75rem;
    border: 1px solid var(--border);
    border-radius: 8px;
    background: var(--bg);
    color: var(--text);
    font: inherit;
    font-size: 0.92rem;
  }

  .chat-widget .chat-input:focus {
    outline: 2px solid var(--accent);
    outline-offset: -1px;
  }

  .chat-widget .chat-send {
    border: none;
    border-radius: 8px;
    background: var(--accent);
    color: #fff;
    padding: 0 0.8rem;
    cursor: pointer;
    display: grid;
    place-items: center;
  }

  .chat-widget .chat-send:disabled {
    opacity: 0.5;
    cursor: default;
  }

  @media (max-width: 480px) {
    .chat-widget {
      right: 0.75rem;
      bottom: 0.75rem;
    }

    .chat-widget .chat-panel {
      width: calc(100vw - 1.5rem);
      height: min(600px, 78vh);
    }
  }
</style>
