---
import { ClientRouter } from 'astro:transitions';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ChatWidget from '../components/ChatWidget.astro';
import site from '../data/site.json';
import profileImg from '../assets/profile.jpg';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  type?: 'website' | 'article';
  /** Set on pages that embed their own chat (e.g. /chat) */
  hideChatWidget?: boolean;
}

const { title, description = site.metaDescription, type = 'website', hideChatWidget = false } = Astro.props;
const pageUrl = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL(profileImg.src, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, interactive-widget=resizes-content" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={pageUrl} />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="alternate" type="application/rss+xml" title={`${site.brandName} — Blog`} href="/rss.xml" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={type} />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <title>{title}</title>
    <ClientRouter />
    <script is:inline>
      // Runs before paint (and re-runs after view-transition swaps) so the
      // chosen theme never flashes. localStorage overrides system preference.
      (function () {
        const apply = () => {
          const saved = localStorage.getItem('theme');
          const theme =
            saved === 'dark' || saved === 'light'
              ? saved
              : matchMedia('(prefers-color-scheme: dark)').matches
                ? 'dark'
                : 'light';
          document.documentElement.dataset.theme = theme;
        };
        apply();
        document.addEventListener('astro:after-swap', apply);
      })();
    </script>
  </head>
  <body>
    <Header />
    <main class="container">
      <slot />
    </main>
    <Footer />
    {!hideChatWidget && <ChatWidget />}
  </body>
</html>
